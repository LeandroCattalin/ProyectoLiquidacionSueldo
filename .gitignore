# == Visual Basic 6.0 Git Ignore ==

# --- Binarios y Compilados ---
*.exe
*.dll
*.ocx

# --- Archivos de Usuario y Temporales de VB6 ---
*.vbw
*.vbc
*.stx
*.scc

# --- Archivos de Compilación y Log ---
*.log
*.obj
*.lib
*.exp
*.res

# --- PRIVACIDAD Y DATOS (Recibos y Capturas) ---
# Bloqueamos TODOS los archivos de recibos generados
*.html
*.htm
*.jpg
*.jpeg

# --- Archivos Temporales de Sistema ---
*.tmp
*.temp
*~
Thumbs.db
ehthumbs.db

# --- Configuración Personal (Sensible) ---
config.ini
*.user

# --- Archivos de Respaldo ---
*.bak