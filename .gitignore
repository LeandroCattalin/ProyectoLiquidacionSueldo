# == Visual Basic 6.0 Git Ignore ==

# --- Binarios y Compilados ---
*.exe
*.dll
*.ocx

# --- Archivos de Usuario y Temporales de VB6 ---
*.vbw
*.vbc
*.stx
*.scc

# --- Archivos de Compilación y Log ---
*.log
*.obj
*.lib
*.exp
*.res

# --- Documentación y Web (HTML) ---
# Ignoramos archivos temporales o de backup de manuales
*.html.tmp
*.html.bak
*.tmp
*.temp
*~
*~.html

# --- Recursos Visuales (JPG y Otros) ---
# Ignoramos miniaturas y archivos de edición pesados
Thumbs.db
ehthumbs.db
*.psd
*.xcf
*.raw
*~.jpg

# --- Configuración Personal (Sensible) ---
config.ini
*.user

# --- Archivos de Respaldo ---
*.bak